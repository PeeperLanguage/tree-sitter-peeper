{
  "name": "tree-sitter-peeper",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the current Peeper language revision",
  "type": "module",
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "tree-sitter",
    "parser",
    "peeper",
    "syntax"
  ],
  "author": "itsfuad",
  "license": "MIT",
  "devDependencies": {
    "tree-sitter-cli": "^0.25.10"
  },
  "optionalDependencies": {
    "nan": "^2.17.0"
  },
  "tree-sitter": [
    {
      "scope": "source.peep",
      "file-types": [
        "peep"
      ],
      "injection-regex": "^peeper$",
      "highlights": [
        "queries/highlights.scm"
      ]
    }
  ],
  "files": [
    "grammar.js",
    "binding.gyp",
    "bindings/node/*",
    "queries/*",
    "src/**"
  ],
  "scripts": {
    "generate": "tree-sitter generate",
    "test": "tree-sitter test",
    "parse": "tree-sitter parse"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PeeperLang/tree-sitter-peeper.git"
  }
}
